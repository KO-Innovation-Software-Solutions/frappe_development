{
  "name": "Frappe",
  "forwardPorts": [8000, 9000, 6787],
  "remoteUser": "frappe",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.live-server",
        "mtxr.sqltools",
        "visualstudioexptteam.vscodeintellicode",
        "cweijan.vscode-database-client2",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "debug.node.autoAttach": "disabled",
         "workbench.colorCustomizations": {
            "activityBar.activeBackground": "#3a6ea5",
            "activityBar.background": "#274472",
            "activityBar.foreground": "#ffffff",
            "activityBar.inactiveForeground": "#f8f8f899",
            "activityBarBadge.background": "#1b2845",
            "activityBarBadge.foreground": "#ffffff",
            "commandCenter.border": "#15202b99",
            "sash.hoverBorder": "#5fa8d3",
            "statusBar.background": "#19376d",
            "statusBar.foreground": "#e7e8e9",
            "statusBarItem.hoverBackground": "#274472",
            "statusBarItem.remoteBackground": "#1b2845",
            "statusBarItem.remoteForeground": "#ffffff",
            "titleBar.activeBackground": "#205295",
            "titleBar.activeForeground": "#fbfbfb",
            "titleBar.inactiveBackground": "#19376d",
            "titleBar.inactiveForeground": "#ffffff99"
        }
      }
    }
  },
  "dockerComposeFile": "./docker-compose.yml",
  "service": "frappe",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "postCreateCommand": {
    "initDevSite": ["python", "installer.py", "--db-type", "mariadb"]
  }
}
